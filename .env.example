# Supabase Environment Configuration
# Copy this file to .env and update with your actual values
# See README.md "Environment Configuration Guide" for detailed instructions

# =============================================================================
# 🔐 SECURITY - GENERATE THESE KEYS (See README for instructions)
# =============================================================================

# JWT Secret - Used to sign/verify JWT tokens
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Anonymous Key - Public API access (RLS policies enforced)
# Generate from JWT secret using Node.js/JWT.io (see README)
# Payload: {"role": "anon", "iss": "supabase"}
SUPABASE_ANON_KEY=your_anon_key_here

# Service Role Key - Server-side access (bypasses RLS)
# Generate from JWT secret using Node.js/JWT.io (see README)
# Payload: {"role": "service_role", "iss": "supabase"}
# ⚠️ NEVER expose this key to clients
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database Password - PostgreSQL password
# Generate with: openssl rand -base64 24
# Testing: Can use "postgres" for local development
# Production: MUST use 32+ character random password
SUPABASE_DB_PASSWORD=your_secure_database_password_here

# =============================================================================
# 🗄️ DATABASE CONFIGURATION
# =============================================================================

# Supabase Project Settings
SUPABASE_PROJECT_ID=xr-future-forests-lab

# PostgreSQL Connection
# Testing: Use defaults (localhost:54322)
# Production: May point to external managed database
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_database_password_here

# =============================================================================
# 🌐 API CONFIGURATION
# =============================================================================

# External API URL
# Testing: http://localhost:54321
# Production: https://api.xrforests.your-domain.com
API_EXTERNAL_URL=http://localhost:54321

# Public REST API endpoint
# Testing: http://localhost:54321/rest/v1
# Production: https://api.xrforests.your-domain.com/rest/v1
PUBLIC_REST_URL=http://localhost:54321/rest/v1

# Public anon key (same as SUPABASE_ANON_KEY)
PUBLIC_ANON_KEY=your_anon_key_here

# =============================================================================
# ☁️ S3 CONFIGURATION (Point Cloud Storage)
# =============================================================================

# S3 Endpoint
# Testing: http://localhost:9000 (MinIO)
# Production: https://s3.amazonaws.com (or your S3 provider)
S3_ENDPOINT=https://s3.amazonaws.com

# S3 Region
# Choose region closest to your server (e.g., eu-central-1, us-east-1)
S3_REGION=us-east-1

# S3 Bucket Name
# Testing: test-pointclouds
# Production: xr-forests-production-pointclouds
S3_BUCKET_NAME=xr-forests-pointclouds

# S3 Credentials
# Testing: minioadmin/minioadmin (MinIO defaults)
# Production: AWS IAM user access keys
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key

# Storage Configuration
STORAGE_BACKEND=s3
STORAGE_FILE_SIZE_LIMIT=2147483648  # 2GB in bytes (for LiDAR files)

# =============================================================================
# 🔐 AUTH CONFIGURATION
# =============================================================================

# Site URL (for email redirects)
# Testing: http://localhost:3000
# Production: https://xrforests.your-domain.com
SITE_URL=http://localhost:3000

# Additional redirect URLs (comma-separated)
ADDITIONAL_REDIRECT_URLS=http://localhost:8000

# JWT Expiry (seconds)
# Testing: 86400 (24 hours)
# Production: 3600 (1 hour) recommended
JWT_EXPIRY=3600

# Enable user signup
# Testing: true (allow registrations)
# Production: false (invite-only, or configure OAuth)
ENABLE_SIGNUP=true

# =============================================================================
# 🖥️ SERVICE PORTS
# =============================================================================

# Supabase Studio (Database Management UI)
STUDIO_PORT=54323

# =============================================================================
# 🚀 ENVIRONMENT
# =============================================================================

# Environment flag
# Options: development | production
ENVIRONMENT=development

# =============================================================================
# 🔌 EXTERNAL SERVICE INTEGRATIONS
# =============================================================================

# EcoSense Sensor Platform
# Testing: http://localhost:8001 (mock server or skip)
# Production: https://api.ecosense.com
ECOSENSE_API_URL=https://api.ecosense.example.com
ECOSENSE_API_KEY=your_ecosense_api_key

# 3DTrees Point Cloud Platform
# Testing: http://localhost:8002 (mock server or skip)
# Production: https://api.3dtrees.com
THREEDTREES_API_URL=https://api.3dtrees.example.com
THREEDTREES_API_KEY=your_3dtrees_api_key

# SILVA Growth Model Service
# Testing: http://localhost:8003 (mock server or skip)
# Production: https://silva-model.your-domain.com
SILVA_MODEL_ENDPOINT=http://silva-model-service:8000
SILVA_MODEL_API_KEY=your_silva_api_key

# =============================================================================
# 📊 MONITORING & LOGGING
# =============================================================================

# Log Level
# Options: debug | info | warn | error
# Testing: debug (verbose for development)
# Production: info (standard logging)
LOG_LEVEL=info

# Enable Query Logging
# Testing: true (helpful for debugging)
# Production: false (reduces noise, enable only when debugging)
ENABLE_QUERY_LOGGING=false

# =============================================================================
# 💾 BACKUP CONFIGURATION
# =============================================================================

# Enable automated backups
# Testing: false (not critical for local dev)
# Production: true (REQUIRED for production)
BACKUP_ENABLED=true

# Backup Schedule (cron format)
# Default: "0 2 * * *" (daily at 2 AM)
BACKUP_SCHEDULE="0 2 * * *"

# Backup Retention Period (days)
# Recommended: 30 days for production
BACKUP_RETENTION_DAYS=30
