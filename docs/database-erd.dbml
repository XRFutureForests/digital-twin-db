// XR Future Forests Lab - Complete Database ERD
// Database Markup Language (DBML) v3.0
// This file contains the complete database schema across all PostgreSQL schemas
// Can be visualized at: https://dbdiagram.io/

Project XRFutureForests {
  database_type: 'PostgreSQL'
  Note: '''
XR Future Forests Lab Database
Unified forest monitoring database with schema organization:
- shared: Reference tables used across all domains (locations, species, campaigns)
- pointclouds: LiDAR scan data and processing variants
- trees: Tree measurement and simulation data with multi-stem support
- sensor: Environmental sensor hardware and time-series readings
- environments: Environmental variants from sensor data or simulations
- imagery: Aerial and ground-based image data with spatial metadata

EXPLICIT RELATIONSHIPS:
This database uses junction tables to explicitly model relationships between shared
tables (ProcessParameters, AuditLog) and domain-specific variant tables. This approach
provides clear foreign key relationships visible in the ERD while maintaining
flexibility for cross-schema operations.

EXTERNAL INTEGRATION:
The sensor schema includes ExternalID and ExternalMetadata columns for integration
with Aquarius API time-series databases, enabling automated sensor data synchronization.

SENSOR-TREE LINKING:
The SensorTreeLinks table enables tracking of individual tree growth and health by
linking dendrometers and sap flow sensors directly to specific trees, supporting
real-time monitoring of tree responses to environmental conditions.
  '''
}

// =============================================================================
// SHARED SCHEMA
// =============================================================================

Table shared.Locations {
  LocationID integer [primary key, note: 'Unique location ID']
  LocationName varchar [note: 'Location name']
  Boundary geometry [note: 'PostGIS polygon for location boundaries']
  CenterPoint geometry [note: 'PostGIS point for location center coordinates']
  Description text [note: 'Description of the location']
  Elevation_m float [note: 'Location elevation']
  Slope_deg float [note: 'Location slope']
  Aspect varchar [note: 'N, NE, E, SE, S, SW, W, NW']
  SoilTypeID integer [ref: > shared.SoilTypes.SoilTypeID, note: 'Soil type reference']
  ClimateZoneID integer [ref: > shared.ClimateZones.ClimateZoneID, note: 'Climate zone reference']
}

Table shared.SoilTypes {
  SoilTypeID integer [primary key]
  SoilTypeName varchar [note: 'Alfisol, Andisol, Aridisol, Entisol, Gelisol, Histosol, Inceptisol, Mollisol, Oxisol, Spodosol, Ultisol, Vertisol']
}

Table shared.ClimateZones {
  ClimateZoneID integer [primary key]
  ClimateZoneName varchar [note: 'Köppen climate classification codes']
}

Table shared.Species {
  SpeciesID integer [primary key, note: 'Unique species ID']
  CommonName varchar [note: 'Common name']
  ScientificName varchar [note: 'Scientific name']
  MaxHeight_m float [note: 'Typical maximum height']
  MaxDBH_cm float [note: 'Typical maximum DBH']
  TypicalLifespan_years integer [note: 'Typical lifespan']
  GrowthRate varchar [note: 'slow, moderate, fast']
  ShadeTolerance varchar [note: 'low, moderate, high, very_high']
  IsDeciduous boolean [note: 'true=deciduous, false=evergreen, NULL=unknown']
}

Table shared.Scenarios {
  ScenarioID integer [primary key]
  ScenarioName varchar [note: 'Current_Conditions, Climate_Change_2050, Drought_Test']
  Description varchar [note: 'Scenario description']
}

Table shared.VariantTypes {
  VariantTypeID integer [primary key]
  VariantTypeName varchar [note: 'original, processed, manual, simulated_growth, user_input, repeat_measurement']
  Description text [note: 'Description of variant type']
}

Table shared.Campaigns {
  CampaignID integer [primary key]
  CampaignName varchar [note: 'Unique campaign identifier']
  CampaignType varchar [note: 'lidar_flight, field_inventory, sensor_deployment, drone_survey, manual_update']
  LocationID integer [ref: > shared.Locations.LocationID, note: 'Location for this campaign']
  StartDate date [note: 'Campaign start date']
  EndDate date [note: 'Campaign end date']
  Description text [note: 'Campaign description']
  Methodology text [note: 'Data collection methodology']
  Equipment text [note: 'Equipment used']
  Personnel text [note: 'Personnel involved']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

Table shared.Plots {
  PlotID integer [primary key, note: 'Unique plot ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Parent location']
  PlotName varchar [not null, note: 'Plot identifier, unique within a location']
  PlotNumber integer [note: 'Numeric plot identifier for ordering']
  Area_m2 float [note: 'Plot area in square meters']
  Boundary geometry [note: 'PostGIS polygon defining plot boundaries in WGS84']
  CenterPoint geometry [note: 'PostGIS point for plot center in WGS84']
  Description text [note: 'Description of the plot']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar

  indexes {
    (LocationID, PlotName) [unique]
  }
}

Table shared.ManagementEvents {
  EventID integer [primary key, note: 'Unique management event ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Location of event']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Optional sub-plot']
  EventType varchar [not null, note: 'thinning, planting, harvesting, pruning, fertilization, prescribed_burn, salvage_logging, site_preparation, other']
  EventDate date [not null, note: 'Event start date']
  EndDate date [note: 'Event end date']
  Description text [note: 'Event description']
  AffectedArea_m2 float [note: 'Area affected by the management activity in m²']
  PerformedBy varchar [note: 'Person or organization performing the activity']
  Notes text [note: 'Additional notes']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

Table shared.DisturbanceEvents {
  EventID integer [primary key, note: 'Unique disturbance event ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Location of disturbance']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Optional sub-plot']
  DisturbanceType varchar [not null, note: 'storm, fire, insect, drought, disease, flood, frost, snow_damage, landslide, other']
  EventDate date [not null, note: 'Disturbance start date']
  EndDate date [note: 'Disturbance end date']
  Severity varchar [note: 'low, moderate, high, severe']
  AffectedArea_m2 float [note: 'Estimated area affected in m²']
  Description text [note: 'Disturbance description']
  Notes text [note: 'Additional notes']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

Table shared.DisturbanceEvents_Trees {
  EventID integer [ref: > shared.DisturbanceEvents.EventID, note: 'References DisturbanceEvents']
  TreeVariantID integer [ref: > trees.Trees.VariantID, note: 'References Trees variant']
  DamageLevel varchar [note: 'none, light, moderate, severe, destroyed']
  Notes text [note: 'Damage notes for individual tree']

  indexes {
    (EventID, TreeVariantID) [pk]
  }
}

Table shared.Processes {
  ProcessID integer [primary key]
  ProcessName varchar [note: 'LiDAR_Segmentation, Tree_Detection, Growth_Simulation, Climate_Modeling']
  AlgorithmName varchar [note: 'RandomForest, DeepLearning, RulesBased, Statistical']
  Version varchar [note: 'v1.0.2, v2.1.0']
  Description text [note: 'Algorithm description and purpose']
  Author varchar [note: 'Algorithm developer/organization']
  PublicationDate date [note: 'When algorithm was published/released']
  Citation text [note: 'Academic citation if applicable']
  Category varchar [note: 'detection, classification, simulation, analysis']
}

Table shared.ProcessParameters {
  ParameterID integer [primary key]
  ParameterName varchar [note: 'learning_rate, max_depth, threshold, growth_rate, interpolation_method']
  ParameterValue varchar [note: 'Actual parameter value used for this variant']
  DataType varchar [note: 'float, int, string, boolean']
  Description text [note: 'Parameter description']
}

// Junction tables for ProcessParameters polymorphic relationships
Table shared.ProcessParameters_PointClouds {
  ParameterID integer [ref: > shared.ProcessParameters.ParameterID, note: 'References ProcessParameters']
  VariantID integer [ref: > pointclouds.PointClouds.VariantID, note: 'References PointClouds variant']

  indexes {
    (ParameterID, VariantID) [pk]
  }
}

Table shared.ProcessParameters_Trees {
  ParameterID integer [ref: > shared.ProcessParameters.ParameterID, note: 'References ProcessParameters']
  VariantID integer [ref: > trees.Trees.VariantID, note: 'References Trees variant']

  indexes {
    (ParameterID, VariantID) [pk]
  }
}

Table shared.ProcessParameters_Environments {
  ParameterID integer [ref: > shared.ProcessParameters.ParameterID, note: 'References ProcessParameters']
  VariantID integer [ref: > environments.Environments.VariantID, note: 'References Environments variant']

  indexes {
    (ParameterID, VariantID) [pk]
  }
}

Table shared.ProcessParameters_Stems {
  ParameterID integer [ref: > shared.ProcessParameters.ParameterID, note: 'References ProcessParameters']
  StemID integer [ref: > trees.Stems.StemID, note: 'References Stems']

  indexes {
    (ParameterID, StemID) [pk]
  }
}

Table shared.ProcessMetrics {
  MetricID integer [primary key]
  ProcessID integer [ref: > shared.Processes.ProcessID, note: 'References Processes']
  MetricName varchar [note: 'accuracy, precision, recall, f1_score, rmse']
  MetricValue float [note: 'Published performance value']
  Source text [note: 'Paper, report, or source of metric']
}

Table shared.AuditLog {
  AuditID bigint [primary key]
  FieldName varchar [note: 'Specific field changed']
  OldValue text [note: 'Previous value (JSON)']
  NewValue text [note: 'New value (JSON)']
  ChangeReason varchar [note: 'User explanation']
  UserID varchar [note: 'User who made change']
  Timestamp timestamp [note: 'When change occurred']
  ChangeType varchar [note: 'field_update, bulk_update, revert']
  IPAddress inet [note: 'IP address of change origin']
  UserAgent text [note: 'Browser/client identification']
}

// Junction tables for AuditLog polymorphic relationships
Table shared.AuditLog_PointClouds {
  AuditID bigint [ref: > shared.AuditLog.AuditID, note: 'References AuditLog']
  VariantID integer [ref: > pointclouds.PointClouds.VariantID, note: 'References PointClouds variant']

  indexes {
    (AuditID, VariantID) [pk]
  }
}

Table shared.AuditLog_Trees {
  AuditID bigint [ref: > shared.AuditLog.AuditID, note: 'References AuditLog']
  VariantID integer [ref: > trees.Trees.VariantID, note: 'References Trees variant']

  indexes {
    (AuditID, VariantID) [pk]
  }
}

Table shared.AuditLog_Environments {
  AuditID bigint [ref: > shared.AuditLog.AuditID, note: 'References AuditLog']
  VariantID integer [ref: > environments.Environments.VariantID, note: 'References Environments variant']

  indexes {
    (AuditID, VariantID) [pk]
  }
}

Table shared.AuditLog_Stems {
  AuditID bigint [ref: > shared.AuditLog.AuditID, note: 'References AuditLog']
  StemID integer [ref: > trees.Stems.StemID, note: 'References Stems']

  indexes {
    (AuditID, StemID) [pk]
  }
}

// =============================================================================
// POINTCLOUDS SCHEMA
// =============================================================================

Table pointclouds.ScannerTypes {
  ScannerTypeID integer [primary key, note: 'Unique scanner type ID']
  ScannerTypeName varchar [unique, note: 'Scanner type name (e.g., Terrestrial_TLS, Aerial_ALS, Mobile_MLS, UAV_ULS)']
  Manufacturer varchar [note: 'Scanner manufacturer']
  Description text [note: 'Scanner type description']
}

Table pointclouds.Scanners {
  ScannerID integer [primary key, note: 'Unique scanner ID']
  ScannerTypeID integer [not null, ref: > pointclouds.ScannerTypes.ScannerTypeID, note: 'Scanner type reference']
  SerialNumber varchar [unique, note: 'Unique hardware serial number']
  AcquisitionDate date [note: 'Date scanner was acquired']
  CalibrationDate date [note: 'Last calibration date']
  Notes text [note: 'Scanner notes']
  CreatedAt timestamp
  UpdatedAt timestamp
}

Table pointclouds.PointClouds {
  VariantID integer [primary key]
  ParentVariantID integer [ref: > pointclouds.PointClouds.VariantID, note: 'Self-reference for variant lineage']
  LocationID integer [ref: > shared.Locations.LocationID, note: 'References shared.Locations']
  ScenarioID integer [ref: > shared.Scenarios.ScenarioID, note: 'References shared.Scenarios - NULL for non-scenario variants']
  VariantTypeID integer [ref: > shared.VariantTypes.VariantTypeID, note: 'References shared.VariantTypes']
  ProcessID integer [ref: > shared.Processes.ProcessID, note: 'References shared.Processes - NULL for original scans']
  CampaignID integer [ref: > shared.Campaigns.CampaignID, note: 'Data collection campaign this scan belongs to']
  ScannerID integer [ref: > pointclouds.Scanners.ScannerID, note: 'Physical scanner hardware used for this scan']
  VariantName varchar [note: 'Descriptive name for variant']
  ScanDate timestamp [note: 'Date and time of original scan']
  SensorModel varchar [note: 'LiDAR scanner model']
  SourceCRS integer [note: 'EPSG code of original coordinate reference system']
  PlatformType varchar [note: 'terrestrial, aerial, mobile, UAV']
  ScanBounds geometry [note: 'PostGIS polygon defining coverage']
  FilePath varchar [note: 'S3 URI to point cloud file']
  FlightAltitude_m float [note: 'Flight altitude above ground in meters (for aerial/UAV)']
  FlightSpeed_ms float [note: 'Platform speed during scanning in m/s']
  ScanAngle_deg float [note: 'Scanner field of view angle in degrees']
  Overlap_percent float [note: 'Swath overlap percentage (for aerial scans)']
  PointCount bigint [note: 'Total number of points']
  PointDensity_per_m2 float [note: 'Average point density in points per square meter']
  FileSizeMB float [note: 'File size in megabytes']
  ProcessingStatus varchar [note: 'pending, processing, completed, failed, cancelled - NULL for original scans']
  ProcessingProgress float [note: 'Processing completion percentage (0-100)']
  ErrorMessage text [note: 'Error details if processing failed']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

// =============================================================================
// TREES SCHEMA
// =============================================================================

Table trees.TreeStatus {
  TreeStatusID integer [primary key]
  TreeStatusName varchar [note: 'healthy, stressed, declining, dead, harvested, missing, downed, broken']
  Description text
}

Table trees.TaperTypes {
  TaperTypeID integer [primary key]
  TaperTypeName varchar [note: 'Cylinder, Cone, Paraboloid, Neiloid']
  Description text [note: 'Form description']
  TypicalTaperRatioMin float [note: 'Typical minimum taper ratio']
  TypicalTaperRatioMax float [note: 'Typical maximum taper ratio']
}

Table trees.StraightnessTypes {
  StraightnessTypeID integer [primary key]
  StraightnessName varchar [note: 'Straight, Slight_sweep, Moderate_sweep, Severe_sweep']
  Description text [note: 'Curvature description']
  DeviationAngleMin float [note: 'Minimum deviation angle in degrees']
  DeviationAngleMax float [note: 'Maximum deviation angle in degrees']
}

Table trees.BranchingPatterns {
  BranchingPatternID integer [primary key]
  BranchingPatternName varchar [note: 'Alternate, Opposite, Whorled, Spiral, Random']
  Description text [note: 'Branching arrangement description']
}

Table trees.BarkCharacteristics {
  BarkCharacteristicID integer [primary key]
  BarkCharacteristicName varchar [note: 'Smooth, Furrowed, Plated, Exfoliating']
  Description text [note: 'Bark texture description']
  TypicalSpecies text [note: 'Examples: e.g., Fagus, Quercus, Pinus, Platanus']
}

Table trees.CrownClasses {
  CrownClassID integer [primary key]
  CrownClassName varchar [note: 'dominant, co_dominant, intermediate, overtopped, open_grown']
  Description text [note: 'Crown competitive/social position (FIA CCLCD / NEON canopyPosition analog)']
}

Table trees.DamageAgents {
  DamageAgentID integer [primary key]
  DamageAgentName varchar [note: 'none, insect, disease, fire, wind, snow_ice, drought, mechanical, animal, human_activity, competition, unknown']
  Description text [note: 'Cause of tree damage, decline, or mortality (FIA AGENTCD analog)']
}

Table trees.Trees {
  VariantID integer [primary key]
  TreeEntityID uuid [note: 'Persistent UUID identifying physical tree across all variants']
  ParentVariantID integer [ref: > trees.Trees.VariantID, note: 'Self-reference for variant lineage']
  PointCloudVariantID integer [ref: > pointclouds.PointClouds.VariantID, note: 'References pointclouds.PointClouds - NULL if not derived from point cloud']
  CampaignID integer [ref: > shared.Campaigns.CampaignID, note: 'Data collection campaign']
  LocationID integer [ref: > shared.Locations.LocationID, note: 'References shared.Locations']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Sub-plot within the location where tree is located']
  ScenarioID integer [ref: > shared.Scenarios.ScenarioID, note: 'References shared.Scenarios']
  VariantTypeID integer [ref: > shared.VariantTypes.VariantTypeID, note: 'References shared.VariantTypes']
  ProcessID integer [ref: > shared.Processes.ProcessID, note: 'References shared.Processes - NULL for manual measurements']
  SpeciesID integer [ref: > shared.Species.SpeciesID, note: 'References shared.Species']
  TreeStatusID integer [ref: > trees.TreeStatus.TreeStatusID, note: 'References TreeStatus']
  BranchingPatternID integer [ref: > trees.BranchingPatterns.BranchingPatternID, note: 'References BranchingPatterns']
  BarkCharacteristicID integer [ref: > trees.BarkCharacteristics.BarkCharacteristicID, note: 'References BarkCharacteristics']
  MeasurementDate date [note: 'Actual date of field measurement']
  DataSourceType varchar [note: 'lidar, field, photogrammetry, estimated, simulated']
  Height_m float [note: 'Total tree height']
  CrownWidth_m float [note: 'Crown diameter']
  CrownBaseHeight_m float [note: 'Height to crown base']
  CrownBoundary geometry [note: 'PostGIS polygon']
  CrownOffsetX_m float [note: 'Crown center offset from trunk (East-West)']
  CrownOffsetY_m float [note: 'Crown center offset from trunk (North-South)']
  Volume_m3 float [note: 'Total tree volume']
  Position geometry [note: 'PostGIS point (tree coordinates)']
  PositionOriginal geometry [note: 'Original CRS coordinates']
  SourceCRS integer [note: 'EPSG code of original coordinate reference system for PositionOriginal']
  LeanAngle_deg float [note: '0-90 degrees from vertical']
  LeanDirection_azimuth integer [note: '0-360 degrees, 0=North']
  TimeDelta_yrs float [note: 'Time since parent variant (for growth)']
  Age_years integer [note: 'Tree age in years']
  HealthScore float [note: '0.0-1.0, overall tree health assessment']
  Biomass_kg float [note: 'Total above-ground biomass']
  CarbonContent_kg float [note: 'Carbon sequestration amount']
  SpeciesConfidence float [note: '0.0-1.0, confidence in species ID']
  PositionConfidence float [note: '0.0-1.0, confidence in position accuracy']
  HeightConfidence float [note: '0.0-1.0, confidence in height measurement']
  CrownClassID integer [ref: > trees.CrownClasses.CrownClassID, note: 'Crown competitive/social position']
  DamageAgentID integer [ref: > trees.DamageAgents.DamageAgentID, note: 'Primary damage/decline agent, if any']
  Defoliation_percent float [note: '0-100, ICP Forests-style defoliation assessment']
  Discolouration_percent float [note: '0-100, ICP Forests-style discolouration assessment']
  CrownTransparency_percent float [note: '0-100, ICP Forests-style crown transparency assessment']
  StatusChangeDate date [note: 'Date when status changed (e.g., mortality)']
  FieldNotes text [note: 'Field observations and FID identifiers']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

Table trees.Stems {
  StemID integer [primary key]
  TreeVariantID integer [ref: > trees.Trees.VariantID, note: 'References Trees.VariantID']
  StemNumber integer [note: '1=main stem, 2+=secondary stems']
  TaperTypeID integer [ref: > trees.TaperTypes.TaperTypeID, note: 'References TaperTypes']
  StraightnessTypeID integer [ref: > trees.StraightnessTypes.StraightnessTypeID, note: 'References StraightnessTypes']
  DBH_cm float [note: 'Diameter at breast height (1.3m)']
  TaperRatio float [note: '0.0-1.0, diameter ratio top/bottom']
  Sweep_cm_per_m float [note: 'Maximum horizontal deviation per meter']
  StemHeight_m float [note: 'Individual stem height']
  StemVolume_m3 float [note: 'Individual stem volume']
  BarkThickness_mm float [note: 'Bark thickness measurement']
  WoodDensity_kg_m3 float [note: 'Wood density for biomass calculations']
  CreatedAt timestamp
  UpdatedAt timestamp
}

Table trees.PhenologyObservations {
  ObservationID integer [primary key, note: 'Unique observation ID']
  TreeVariantID integer [not null, ref: > trees.Trees.VariantID, note: 'References Trees variant']
  ObservationDate date [not null, note: 'Date of phenology observation']
  PhenophaseType varchar [not null, note: 'bud_break, leaf_out, flowering, fruit_set, leaf_color, leaf_fall, dormancy']
  PhenophaseStatus varchar [note: 'not_started, beginning, intermediate, peak, ending, completed']
  Intensity_percent float [note: 'Intensity of the phenophase (0-100%)']
  Observer varchar [note: 'Observer name']
  Notes text [note: 'Observation notes']
  CreatedAt timestamp
  CreatedBy varchar
}

Table trees.Deadwood {
  DeadwoodID integer [primary key, note: 'Unique deadwood ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Location reference']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Optional sub-plot']
  TreeVariantID integer [ref: > trees.Trees.VariantID, note: 'Optional link to known dead tree variant']
  SpeciesID integer [ref: > shared.Species.SpeciesID, note: 'Species reference']
  WoodType varchar [not null, note: 'standing, fallen, stump, branch']
  Length_m float [note: 'Length in meters']
  Diameter_cm float [note: 'Diameter in centimeters']
  DecayClass integer [note: 'Decay stage from 1 (fresh) to 5 (fully decomposed)']
  Volume_m3 float [note: 'Volume in cubic meters']
  Position geometry [note: 'PostGIS point for deadwood location']
  MeasurementDate date [note: 'Date of measurement']
  Notes text [note: 'Additional notes']
  CreatedAt timestamp
  CreatedBy varchar
}

Table trees.GroundVegetation {
  VegetationID integer [primary key, note: 'Unique vegetation record ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Location reference']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Optional sub-plot']
  SpeciesName varchar [note: 'Vegetation species name']
  CoverPercent float [note: 'Estimated cover percentage (0-100)']
  Height_cm float [note: 'Vegetation height in centimeters']
  Layer varchar [note: 'herb, shrub, moss, litter, fern, grass']
  MeasurementDate date [note: 'Date of measurement']
  Notes text [note: 'Additional notes']
  CreatedAt timestamp
  CreatedBy varchar
}

// =============================================================================
// SENSOR SCHEMA
// =============================================================================

Table sensor.SensorTypes {
  SensorTypeID integer [primary key]
  SensorTypeName varchar [note: 'Temperature, Humidity, CO2, Light, Soil_Moisture, Wind']
  Description text
}

Table sensor.Sensors {
  SensorID integer [primary key]
  LocationID integer [ref: > shared.Locations.LocationID, note: 'References shared.Locations']
  SensorTypeID integer [ref: > sensor.SensorTypes.SensorTypeID]
  CampaignID integer [ref: > shared.Campaigns.CampaignID, note: 'Deployment campaign this sensor was installed during']
  SensorModel varchar [note: 'Specific sensor model']
  SerialNumber varchar [note: 'Unique sensor identifier']
  Position geometry [note: 'Sensor position within location']
  PositionOriginal geometry [note: 'Original CRS coordinates']
  SourceCRS integer [note: 'EPSG code of original coordinate reference system for PositionOriginal']
  InstallationDate timestamp
  InstallationHeight_m float [note: 'Height of sensor installation above ground in meters']
  DecommissionDate timestamp [note: 'NULL if still active']
  CalibrationDate timestamp
  NextCalibrationDate timestamp
  SamplingInterval_seconds integer
  ReadingType varchar [note: 'Temperature, Humidity, etc.']
  Unit varchar
  MinValue float [note: 'Sensor range minimum']
  MaxValue float [note: 'Sensor range maximum']
  Accuracy float [note: 'Sensor accuracy specification']
  BatteryLevel_percent float [note: 'Current battery level']
  IsActive boolean [note: 'Sensor operational status']
  MaintenanceNotes text
  ExternalID varchar [note: 'External system identifier (Aquarius time series ID)']
  ExternalMetadata jsonb [note: 'Additional metadata from external systems']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

Table sensor.SensorReadings {
  ReadingID bigint [primary key]
  SensorID integer [ref: > sensor.Sensors.SensorID, note: 'References sensors.Sensors']
  Timestamp timestamp [note: 'Reading timestamp']
  Value float
  Quality varchar [note: 'good, suspect, bad']
  ScenarioID integer [ref: > shared.Scenarios.ScenarioID, note: 'References shared.Scenarios - NULL for real readings']
  BatteryVoltage float [note: 'Sensor battery voltage at reading time']
  SignalStrength float [note: 'Communication signal strength']
  Notes text [note: 'Additional notes about this reading']
  CreatedAt timestamp [note: 'Reading creation timestamp']
}

Table sensor.SensorTreeLinks {
  LinkID integer [primary key]
  SensorID integer [ref: > sensor.Sensors.SensorID, note: 'References Sensors']
  TreeVariantID integer [ref: > trees.Trees.VariantID, note: 'References Trees variant']
  Description text [note: 'Link description and automated matching notes']
  StartDate date [note: 'Start date of sensor-tree link']
  EndDate date [note: 'End date of sensor-tree link']
  CreatedAt timestamp [note: 'Link creation timestamp']
}

// =============================================================================
// ENVIRONMENTS SCHEMA
// =============================================================================

Table environments.Environments {
  VariantID integer [primary key]
  ParentVariantID integer [ref: > environments.Environments.VariantID, note: 'Self-reference for variant lineage']
  LocationID integer [ref: > shared.Locations.LocationID, note: 'References shared.Locations']
  ScenarioID integer [ref: > shared.Scenarios.ScenarioID, note: 'References shared.Scenarios']
  VariantTypeID integer [ref: > shared.VariantTypes.VariantTypeID, note: 'References shared.VariantTypes']
  ProcessID integer [ref: > shared.Processes.ProcessID, note: 'References shared.Processes - NULL for manual input']
  VariantName varchar [note: 'Descriptive name for variant']
  StartDate timestamp [note: 'Period start date']
  EndDate timestamp [note: 'Period end date']
  AvgTemperature_C float
  AvgHumidity_percent float
  TotalPrecipitation_mm float
  AvgGlobalRadiation_W_m2 float [note: 'Average global radiation in W/m²']
  AvgCO2_ppm float
  AvgWindSpeed_ms float
  DominantWindDirection_deg float
  AvgSoilMoisture_percent float [note: 'Average soil moisture content']
  AvgSoilTemperature_C float [note: 'Average soil temperature']
  SoilPH float [note: 'Soil acidity/alkalinity']
  NutrientNitrogen_mg_kg float [note: 'Nitrogen content in soil']
  NutrientPhosphorus_mg_kg float [note: 'Phosphorus content in soil']
  NutrientPotassium_mg_kg float [note: 'Potassium content in soil']
  StressFactor float [note: '0.0-1.0, combined environmental stress indicator']
  Description text
  ResearchNotes text [note: 'Scientific observations and analysis notes']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

// =============================================================================
// IMAGERY SCHEMA
// =============================================================================

Table imagery.Images {
  ImageID integer [primary key, note: 'Unique image ID']
  LocationID integer [not null, ref: > shared.Locations.LocationID, note: 'Location reference']
  PlotID integer [ref: > shared.Plots.PlotID, note: 'Optional sub-plot']
  CampaignID integer [ref: > shared.Campaigns.CampaignID, note: 'Data collection campaign']
  CaptureDate timestamp [note: 'Image capture date and time']
  FilePath text [not null, note: 'Path or URI to image file']
  FileFormat varchar [note: 'jpg, png, tiff, raw, geotiff']
  Resolution_px varchar [note: 'Image resolution in pixels (e.g., 4000x3000)']
  CameraModel varchar [note: 'Camera model used']
  Position geometry [note: 'Camera position in WGS84']
  Altitude_m float [note: 'Camera altitude above ground in meters']
  Heading_deg float [note: 'Camera heading in degrees (0=North, clockwise)']
  Pitch_deg float [note: 'Camera pitch angle (-90 to 90 degrees)']
  Roll_deg float [note: 'Camera roll angle (-180 to 180 degrees)']
  GroundSampleDistance_cm float [note: 'Ground sample distance in centimeters per pixel']
  Description text [note: 'Image description']
  CreatedAt timestamp
  UpdatedAt timestamp
  CreatedBy varchar
  UpdatedBy varchar
}

// =============================================================================
// TABLE GROUPS (Schema Organization)
// =============================================================================

TableGroup "Shared Schema" {
  shared.Locations
  shared.SoilTypes
  shared.ClimateZones
  shared.Species
  shared.Scenarios
  shared.VariantTypes
  shared.Campaigns
  shared.Plots
  shared.ManagementEvents
  shared.DisturbanceEvents
  shared.DisturbanceEvents_Trees
  shared.Processes
  shared.ProcessParameters
  shared.ProcessParameters_PointClouds
  shared.ProcessParameters_Trees
  shared.ProcessParameters_Environments
  shared.ProcessParameters_Stems
  shared.ProcessMetrics
  shared.AuditLog
  shared.AuditLog_PointClouds
  shared.AuditLog_Trees
  shared.AuditLog_Environments
  shared.AuditLog_Stems
}

TableGroup "Point Clouds Schema" {
  pointclouds.ScannerTypes
  pointclouds.Scanners
  pointclouds.PointClouds
}

TableGroup "Trees Schema" {
  trees.TreeStatus
  trees.TaperTypes
  trees.StraightnessTypes
  trees.BranchingPatterns
  trees.BarkCharacteristics
  trees.Trees
  trees.Stems
  trees.PhenologyObservations
  trees.Deadwood
  trees.GroundVegetation
  trees.CrownClasses
  trees.DamageAgents
}

TableGroup "Sensor Schema" {
  sensor.SensorTypes
  sensor.Sensors
  sensor.SensorReadings
  sensor.SensorTreeLinks
}

TableGroup "Environments Schema" {
  environments.Environments
}

TableGroup "Imagery Schema" {
  imagery.Images
}


